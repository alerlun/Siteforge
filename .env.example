# Copy this file to .env and fill in real values. NEVER commit .env / .env.test / .env.live
# (they are gitignored). VITE_* vars are bundled into the client and are public by design;
# everything else is server-only and must live in Supabase Edge secrets / Vercel env, not
# in client code.

# ── Client (public — shipped in the browser bundle) ─────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
# Google Analytics 4 measurement ID (G-XXXXXXXXXX). Public by design. If unset,
# analytics + the consent banner are disabled (no-op).
VITE_GA_MEASUREMENT_ID=

# ── Supabase (server-only) ──────────────────────────────────────────────────
# SUPABASE_URL mirrors VITE_SUPABASE_URL for Edge Functions. Service role key is a
# master key that bypasses RLS — keep it server-side only, rotate on any suspected leak.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI site generation (Anthropic) ──────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Lead scraping ───────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=

# Rate limiting needs no env vars — it is Postgres-backed (see supabase/schema.sql,
# check_rate_limit()) and runs on the existing service-role DB connection.

# ── Stripe ──────────────────────────────────────────────────────────────────
# The active key set is chosen at runtime by the `stripe_mode` row in the `config`
# table ('test' | 'live'). In live mode the *_LIVE vars are mandatory (no fallback).
# Test mode prefers *_TEST and falls back to the legacy unsuffixed vars below.
STRIPE_SECRET_KEY_TEST=
STRIPE_PRO_PRICE_ID_TEST=
STRIPE_WEBHOOK_SECRET_TEST=

STRIPE_SECRET_KEY_LIVE=
STRIPE_PRO_PRICE_ID_LIVE=
STRIPE_WEBHOOK_SECRET_LIVE=

# Legacy unsuffixed fallbacks (used only in test mode if *_TEST are absent).
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
